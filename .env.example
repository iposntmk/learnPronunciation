VITE_AZURE_KEY=your_azure_speech_key_here
VITE_AZURE_REGION=southeastasia
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional practice-word images
# Use a Pollinations publishable key only; do not put secret keys in Vite env files.
VITE_POLLINATIONS_API_KEY=
VITE_POLLINATIONS_IMAGE_MODEL=

# Optional Google Images via Google Custom Search JSON API / Programmable Search Engine.
VITE_GOOGLE_IMAGE_SEARCH_API_KEY=
VITE_GOOGLE_IMAGE_SEARCH_CX=
