AZURE_KEY=your_azure_speech_key_here
AZURE_REGION=southeastasia
VITE_AZURE_PROXY_URL=/api
VITE_ELEVENLABS_TTS_URL=/api/elevenlabs/tts
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Audio mẫu TTS (Node/Vercel backend proxy; do not expose the API key with VITE_)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional SpeechSuper word-stress assessor (Node backend proxy; do not expose secrets with VITE_)
VITE_SPEECHSUPER_PROXY_URL=/api/speechsuper/pronunciation
SPEECHSUPER_APP_KEY=
SPEECHSUPER_SECRET_KEY=

# Optional practice-word images
# Use a Pollinations publishable key only; do not put secret keys in Vite env files.
VITE_POLLINATIONS_API_KEY=
VITE_POLLINATIONS_IMAGE_MODEL=

# Optional Google Images via Google Custom Search JSON API / Programmable Search Engine.
VITE_GOOGLE_IMAGE_SEARCH_API_KEY=
VITE_GOOGLE_IMAGE_SEARCH_CX=
