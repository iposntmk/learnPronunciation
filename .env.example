ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional SpeechSuper word-stress assessor (Node backend proxy; do not expose secrets with VITE_)
VITE_SPEECHSUPER_PROXY_URL=/api/speechsuper/pronunciation
SPEECHSUPER_APP_KEY=
SPEECHSUPER_SECRET_KEY=
